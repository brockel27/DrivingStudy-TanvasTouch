<Window x:Class="TanvasTouchHapticKnob.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TanvasTouchHapticKnob"
        mc:Ignorable="d"
        Background="#58609A"
        Width="400"
        Height="400"
        Title="TanvasTouch: Haptic Knob">
    <Grid Margin="40">
        <!-- The main canvas that contains the "moving" part of the knob. The center of this canvas forms the center of the knob. -->
        <Canvas x:Name="KnobCanvas" Width="302" Height="302">

            <!-- The base image for the knob -->
            <Image Source="assets/background/base.png" Stretch="None"/>
            
            <!-- This is the element that is actually rotated when the user interacts with the knob. -->
            <Canvas Name="KnobRotate" Width="302" Height="302" Panel.ZIndex="10">

                <!-- The frame for the knob -->
                <Image Source="assets/background/frame.png" Stretch="None"/>
                
                <Image Source="assets/background/knob.png" Stretch="None">
                    <Canvas.Top>27</Canvas.Top>
                    <Canvas.Left>27</Canvas.Left>
                </Image>
                
                <!-- The nub which the user must interact with in order to rotate the knob. -->
                <Grid Name="KnobNub">
                    <Canvas.Left>181</Canvas.Left>
                    <Canvas.Top>123</Canvas.Top>
                    <Image Name="NubDeselected" Source="assets/nub/deselected.png" Stretch="None" Visibility="Visible"/>
                    <Image Name="NubSelected" Source="assets/nub/selected.png" Stretch="None" Visibility="Hidden"/>
                </Grid>
            </Canvas>
        </Canvas>

    </Grid>
</Window>
